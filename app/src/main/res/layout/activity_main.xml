<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface_variant"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/vpnStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stopped"
            android:textColor="@color/player_hostile"
            android:textStyle="bold"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/entityCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entities: 0"
            android:textColor="@color/on_surface"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/zoneName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Zone: -"
            android:textColor="@color/on_surface"
            android:textAlignment="textEnd" />

    </LinearLayout>

    <!-- Radar View -->
    <com.albionradar.ui.RadarView
        android:id="@+id/radarView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintBottom_toTopOf="@id/controlPanel" />

    <!-- Control Panel -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/tabLayout">

        <Button
            android:id="@+id/btnStartVpn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_vpn"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnOverlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/show_overlay"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings" />

    </LinearLayout>

    <!-- Tab Layout for Entity Lists -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:tabTextColor="@color/on_surface"
        app:tabSelectedTextColor="@color/accent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resources" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mobs" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/players" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dungeons" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Entity List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/entityList"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/surface_variant"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@android:layout/simple_list_item_2" />

</androidx.constraintlayout.widget.ConstraintLayout>
